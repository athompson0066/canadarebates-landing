{
  "version": 2,
  "name": "canadarebates-landing",
  "public": true,
  "github": {
    "enabled": true,
    "autoAlias": true
  },
  "routes": [
    { "src": "/verify", "dest": "/verify.html" },
    { "src": "/verify\\?.*", "dest": "/verify.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}